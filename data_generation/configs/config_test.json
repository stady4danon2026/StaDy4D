{
  "description": "Quick test - unified pipeline with attached + free cameras",

  "carla": {
    "host": "localhost",
    "port": 2000,
    "timeout": 10.0
  },

  "maps": [
    "Town01",
    "Town03",
    "Town04",
    "Town06"
  ],

  "video_generation": {
    "videos_per_map": 1,
    "video_duration_sec": 5,
    "fps": 10,
    "trajectory_types": []
  },

  "multi_camera_types": [
    "round_building",
    "round_building",
    "round_building",
    "round_building",
    "round_building",
    "round_building",
    "round_building"
  ],

  "camera": {
    "width": 640,
    "height": 480,
    "fov": 70
  },

  "actors": {
    "n_vehicles": 80,
    "n_walkers": 50
  },

  "weather": ["ClearNoon"],

  "output": {
    "base_dir": "StaDy4D/Test",
    "create_videos": true,
    "save_rgb": true,
    "save_depth": true,
    "save_depth_vis": true,
    "save_extrinsics": true
  },

  "random_seed": 41,

  "execution": {
    "skip_existing": false,
    "resume_from_map": null,
    "resume_from_video": null,
    "disable_resume": true
  }
}
