{
  "description": "Large Scale Production - All maps, many videos",

  "carla": {
    "host": "localhost",
    "port": 2000,
    "timeout": 10.0
  },

  "maps": [
    "Town03"
  ],

  "video_generation": {
    "videos_per_map": 9,
    "video_duration_sec": 5,
    "fps": 10,
    "trajectory_types": []
  },

  "multi_camera_types": [
    "car_forward",
    "car_forward",
    "car_forward",
    "drone_forward",
    "orbit_building",
    "orbit_crossroad",
    "cctv",
    "pedestrian",
    "pedestrian"
  ],

  "camera": {
    "width": 640,
    "height": 480,
    "fov": 70
  },

  "actors": {
    "n_vehicles": 80,
    "n_walkers": 50
  },

  "weather": ["ClearNoon", "HardRainNoon", "ClearNoon", "MidRainSunset", "ClearNoon", "WetCloudyNoon"],

  "output": {
    "base_dir": "StaDy4D/ShortVid",
    "create_videos": true,
    "save_rgb": true,
    "save_depth": true,
    "save_depth_vis": true,
    "save_extrinsics": true
  },

  "random_seed": 42,

  "execution": {
    "skip_existing": false,
    "resume_from_map": null,
    "resume_from_video": null,
    "disable_resume": true
  }
}
